{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM"],
    "types": ["vite/client", "node"]
  },
  "include": ["src/**/*.ts", "vite.config.ts"]
}
